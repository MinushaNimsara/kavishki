  "grammar": {
    "easy": [
      {
        "q": "She ___ to school.",
        "options": [
          "go",
          "goes",
          "going",
          "gone"
        ],
        "answer": "goes",
        "hint": "He/She/It usually takes -s."
      },
      {
        "q": "They ___ happy.",
        "options": [
          "is",
          "are",
          "am",
          "be"
        ],
        "answer": "are",
        "hint": "They → are."
      },
      {
        "q": "I ___ a book.",
        "options": [
          "have",
          "has",
          "having",
          "had"
        ],
        "answer": "have",
        "hint": "I/You/We/They → have."
      },
      {
        "q": "An ___ is red.",
        "options": [
          "banana",
          "apple",
          "chair",
          "dog"
        ],
        "answer": "apple",
        "hint": "Use 'an' before vowel sound."
      },
      {
        "q": "We ___ football.",
        "options": [
          "play",
          "plays",
          "playing",
          "played"
        ],
        "answer": "play",
        "hint": "We → base verb."
      }
    ],
    "medium": [
      {
        "q": "He ___ not like milk.",
        "options": [
          "do",
          "does",
          "did",
          "doing"
